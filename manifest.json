{
  "manifest_version": 3,
  "name": "Cache-Bust Auto Refresh",
  "version": "1.0.0",
  "description": "Auto-refresh pages with a changing query parameter and best-effort no-cache request headers.",
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Cache-Bust Auto Refresh",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
